from crypto import generate_key, encrypt, decrypt
from storage import load_data, save_data
from color import red, green

#--- Adds passwords ---
def add_password(data):
	site = input("Site: ")
	username = input("Username: ")
	password = input("Password: ")

	encrypted = encrypt(password)

	data.append({
		"site": site,
		"username": username,
		"password": encrypted
	})

	save_data(data)
	print(green("Saved securely."))

#--- View Passwords ---
def view_passwords(data):
	for item in data:
		print("\nSite:", item["site"])
		print("User:", item["username"])
		print("Pass:", decrypt(item["password"]))
#--- Menu ---
def menu():
	print("\n---PASSWORD MANAGER ---")
	print("1 Add password")
	print("2 View passswords")
	print("3 Quit")

#--- Main ---
def main():

	try:
		open("key.key")
	except:
		generate_key()

	data = load_data()

	while True:
		menu()
		choice = input("Choose: ")

		if choice == "1"zzz	add_password(data)
		elif choice == "2":
			view_passwords(data)
		elif choice == "3":
			break
		else:
			print(red("INVALID"))

if __name__ == "__main__":
	main()

